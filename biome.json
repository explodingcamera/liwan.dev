{
	"$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
	"assist": {
		"enabled": true,
		"actions": {
			"preset": "recommended",
			"source": { "preset": "recommended", "organizeImports": "off" }
		}
	},
	"formatter": {
		"lineWidth": 100,
		"indentStyle": "tab"
	},
	"linter": {
		"enabled": true,
		"rules": {
			"preset": "recommended",
			"a11y": { "noSvgWithoutTitle": "off" },
			"suspicious": {
				"noArrayIndexKey": "off",
				"noDuplicateProperties": "off"
			},
			"complexity": {
				"noUselessFragments": "off",
				"noImportantStyles": "off"
			},
			"style": {
				"noDescendingSpecificity": "off",
				"noNonNullAssertion": "off"
			},
			"correctness": {
				"useUniqueElementIds": "off",
				"noUnusedVariables": {
					"fix": "none",
					"level": "warn"
				}
			}
		}
	},
	"files": {
		"includes": ["**", "!**/dist/*", "!**/spec.ts*", "!**/.astro/*"]
	},
	"overrides": [
		{
			"includes": ["**/*.astro"],
			"linter": {
				"rules": {
					"correctness": {
						"noUnusedImports": "off",
						"noUnusedVariables": "off"
					}
				}
			}
		}
	]
}
